{
	"name": "zatiaraspos",
	"private": true,
	"version": "2.0.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build && node scripts/export-durable-objects.mjs",
		"deploy:check": "node scripts/verify-cloudflare-deploy-config.mjs",
		"deploy:realtime": "wrangler deploy --config wrangler.realtime.jsonc",
		"deploy:pages": "wrangler pages deploy .svelte-kit/cloudflare --project-name zatiaraspos --branch main --commit-dirty=true",
		"deploy:all": "pnpm deploy:check && pnpm build && pnpm deploy:realtime && pnpm deploy:pages",
		"d1:backup": "node scripts/d1-backup.mjs",
		"d1:restore": "node scripts/d1-restore.mjs",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test:features": "tsx src/tests/feature-tests.ts",
		"test:features:all": "tsx src/tests/feature-tests.ts all",
		"test:features:dashboard": "tsx src/tests/feature-tests.ts dashboard",
		"test:features:pos": "tsx src/tests/feature-tests.ts pos",
		"test:features:reporting": "tsx src/tests/feature-tests.ts reporting",
		"test:features:recording": "tsx src/tests/feature-tests.ts recording",
		"test:features:settings": "tsx src/tests/feature-tests.ts settings",
		"test:features:auth": "tsx src/tests/feature-tests.ts auth",
		"test:features:data": "tsx src/tests/feature-tests.ts data",
		"test:quality": "tsx src/tests/code-quality-tests.ts",
		"test:quality:all": "tsx src/tests/code-quality-tests.ts all",
		"test:quality:typescript": "tsx src/tests/code-quality-tests.ts typescript",
		"test:quality:linting": "tsx src/tests/code-quality-tests.ts linting",
		"test:quality:structure": "tsx src/tests/code-quality-tests.ts structure",
		"test:quality:dependencies": "tsx src/tests/code-quality-tests.ts dependencies",
		"test:all": "pnpm test:quality && pnpm test:features",
		"test:offline": "tsx src/tests/offline-pos-tests.ts",
		"test:checkout:local": "node scripts/uat-checkout-financials.mjs",
		"test:receipt-output": "tsx src/tests/receipt-output-tests.ts",
		"test:report-grouping": "tsx src/tests/report-grouping-tests.ts",
		"test:csp:local": "node scripts/uat-csp-pages.mjs",
		"test:csrf:local": "node scripts/uat-csrf-mutations.mjs",
		"test:final:local": "node scripts/uat-final-workflows.mjs",
		"test:security:local": "node scripts/uat-security-rate-limits.mjs",
		"test:load:checkout": "node scripts/loadtest-checkout.mjs",
		"d1:setup:local": "node scripts/setup-local-d1.mjs"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^4.20260619.1",
		"@eslint/compat": "^1.2.5",
		"@eslint/js": "^9.18.0",
		"@sveltejs/adapter-cloudflare": "^7.2.8",
		"@sveltejs/kit": "^2.60.1",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"@tailwindcss/postcss": "^4.1.11",
		"@tailwindcss/vite": "^4.0.0",
		"@types/better-sqlite3": "^7.6.13",
		"@types/node": "^26.0.0",
		"@types/pako": "^2.0.4",
		"@types/uuid": "^11.0.0",
		"autoprefixer": "^10.4.21",
		"drizzle-kit": "^0.31.10",
		"eslint": "^9.18.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^3.0.0",
		"globals": "^16.0.0",
		"postcss": "^8.5.6",
		"prettier": "^3.4.2",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"rollup-plugin-visualizer": "^6.0.3",
		"svelte": "^5.55.8",
		"svelte-check": "^4.0.0",
		"tailwindcss": "^4.1.11",
		"tsx": "^4.19.2",
		"typescript": "^5.0.0",
		"typescript-eslint": "^8.20.0",
		"vite": "^6.4.2",
		"wrangler": "^4.92.0"
	},
	"dependencies": {
		"@khmyznikov/pwa-install": "^0.6.3",
		"@vite-pwa/sveltekit": "^1.0.0",
		"bcryptjs": "^3.0.2",
		"drizzle-orm": "^0.45.2",
		"idb-keyval": "^6.2.2",
		"js-base64": "^3.7.7",
		"lucide-svelte": "^0.535.0",
		"pako": "^2.1.0",
		"uuid": "^11.1.1",
		"workbox-window": "^7.3.0"
	}
}
